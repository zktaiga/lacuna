# Copy to .env and fill in real values. .env is gitignored.

# --- Telegram (mandatory) ---
LACUNA_TELEGRAM_BOT_TOKEN=
LACUNA_TELEGRAM_GROUP_CHAT_ID=

# --- Operator credentials ---
# If empty, the bot will warn at startup and refuse to poll.
LACUNA_OPERATOR_EMAIL=
LACUNA_OPERATOR_PASSWORD=

# --- Backend identification (operator-specific) ---
# Real values supplied at deployment; left blank in source.
LACUNA_BACKEND_BASE_URL=
LACUNA_BACKEND_CLIENT_PACKAGE=
LACUNA_BACKEND_CLIENT_BUILD=

# --- Optional session/request diagnostics ---
# Persist provider session cookies across container restarts. The Docker
# compose file mounts /app/data as a named volume.
LACUNA_SESSION_CACHE_PATH=/app/data/session.json
LACUNA_SESSION_CACHE_MAX_AGE_MINUTES=43200

# If true, logs provider request method/path/status/timing at info level.
# Otherwise the same data is available at debug level.
LACUNA_LOG_PROVIDER_REQUESTS=false
